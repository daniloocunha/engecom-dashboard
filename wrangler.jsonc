{
  // Worker principal (proxy reverso para Apps Script + arquivos estáticos)
  "name": "engecom-dashboard",
  "main": "src/worker.js",
  "compatibility_date": "2026-02-20",
  "assets": {
    "directory": "./dashboard"
  },

  // Variáveis de ambiente do Worker (não são segredos, podem ficar aqui)
  "vars": {
    // URL de implantação do Google Apps Script
    // Atualizar aqui quando uma nova implantação for criada no Apps Script
    "APPS_SCRIPT_URL": "https://script.google.com/macros/s/AKfycbwAGDpVAJc-z4J0K9_F7yCwNebqWDNG7LhDyvhROFIMOXJ2k3bnfsjE9_mDfNssbZOl6g/exec"
  }
}
