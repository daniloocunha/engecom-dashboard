<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="?attr/colorSecondaryContainer">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvDescricaoServicoRDO"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nome do Serviço"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSecondaryContainer"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/tvQuantidadeServicoRDO"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Quantidade: 10.5"
                    android:textSize="12sp"
                    android:textColor="?attr/colorOnSurfaceVariant"/>

                <TextView
                    android:id="@+id/tvBadgeCustomizadoRDO"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CUSTOMIZADO"
                    android:textSize="10sp"
                    android:textColor="#FF6F00"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp"
                    android:visibility="gone"/>

                <TextView
                    android:id="@+id/tvObservacoesRDO"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Obs: Observação do serviço"
                    android:textSize="11sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textStyle="italic"
                    android:layout_marginTop="4dp"
                    android:visibility="gone"/>

            </LinearLayout>

            <ImageButton
                android:id="@+id/btnEditarServicoRDO"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_edit"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Editar serviço"
                app:tint="?attr/colorTertiary"
                tools:ignore="HardcodedText" />

            <ImageButton
                android:id="@+id/btnRemoverServicoRDO"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_delete"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Remover serviço"
                app:tint="?attr/colorError"
                tools:ignore="HardcodedText" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>