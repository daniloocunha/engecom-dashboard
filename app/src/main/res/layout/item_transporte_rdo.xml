<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/Widget.Material3.CardView.Filled"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="?attr/colorSecondaryContainer">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvDescricaoTransporte"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/transporte_de_cabos"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:textColor="?attr/colorOnSecondaryContainer" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvColaboradoresTransporte"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="👥 3 colaboradores"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="?attr/colorOnSecondaryContainer" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvHorarioTransporte"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="🕐 08:00 - 09:30"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="?attr/colorOnSecondaryContainer" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvDistanciaTransporte"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="📍 KM 123.0 → 145.5 (22.5 km)"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:textColor="?attr/colorOnSecondaryContainer"
                android:textStyle="bold" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnEditarTransporte"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="center_vertical"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Editar Transporte"
            android:src="@android:drawable/ic_menu_edit"
            app:tint="#FFA000" />

        <ImageButton
            android:id="@+id/btnRemoverTransporte"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="center_vertical"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Remover Transporte"
            android:src="@android:drawable/ic_menu_delete"
            app:tint="#D32F2F" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
